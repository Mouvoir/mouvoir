# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.idea

.playwright-mcp

.superpowers

# full backup of public/ video masters (7+ GB, keep local only)
doc/public_backup

# design master videos in doc/ — exceed GitHub's 100MB/file & 2GB/pack limits,
# keep local only (the web-encoded versions the site uses live in public/)
doc/**/*.mov
doc/**/*.webm